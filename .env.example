# -----------------------
# Database
# -----------------------
DB_HOST=db
DB_PORT=3306
DB_NAME=raidcontrol
DB_USER=raid
DB_PASSWORD=raidpass

# -----------------------
# Device ingest auth
# -----------------------
DEVICE_API_KEY=changeme-device-key

# -----------------------
# Admin auth (simple)
# -----------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
JWT_SECRET=changeme-jwt-secret
JWT_EXPIRES_MIN=720

# -----------------------
# App
# -----------------------
UPLOAD_DIR=uploads
NEEDS_REVIEW_MIN_CONF=0.60
FINISH_CHECKPOINT_ID=finish

# -----------------------
# DigitalOcean Spaces (S3-compatible, optional)
# -----------------------
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET=
SPACES_REGION=nyc3
